# =============================================================================
# .env.example — 이 파일을 .env로 복사 후 값 채우기
# 주의:
#   - .env 파일은 절대 git에 커밋하지 말 것 (.gitignore에 의해 차단됨)
#   - 시크릿 값만 둘 것. 구조(host/port/db명 등)는 configs/connections.yaml
# =============================================================================

# === RDBMS ===
PG_PROD_PASSWORD=changeme
MYSQL_ANALYTICS_PASSWORD=changeme
ORACLE_LEGACY_PASSWORD=changeme
MSSQL_SA_PASSWORD=changeme

# === Cloud DW ===
SNOWFLAKE_PRIVATE_KEY_PATH=/secrets/sf_key.p8
BIGQUERY_SERVICE_ACCOUNT_JSON=/secrets/bq-sa.json
REDSHIFT_PASSWORD=changeme
CLICKHOUSE_PASSWORD=changeme

# === NoSQL ===
MONGO_URI_PASSWORD=changeme
REDIS_PASSWORD=changeme
CASSANDRA_PASSWORD=changeme
DYNAMODB_AWS_ACCESS_KEY_ID=
DYNAMODB_AWS_SECRET_ACCESS_KEY=

# === Stream ===
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=
KINESIS_AWS_ACCESS_KEY_ID=
KINESIS_AWS_SECRET_ACCESS_KEY=
PULSAR_TOKEN=
RABBITMQ_PASSWORD=changeme

# === Object Storage ===
S3_ACCESS_KEY=
S3_SECRET_KEY=
GCS_SERVICE_ACCOUNT_JSON=
AZURE_BLOB_CONNECTION_STRING=

# === Secret Backend (선택) ===
SECRET_BACKEND=env            # env | vault | aws_sm | gcp_sm
VAULT_ADDR=
VAULT_TOKEN=

# === Local dev infra (docker-compose.dev.yml에서 사용) ===
# 로컬 docker 컨테이너 자격증명. 운영에서는 사용 금지.
LOCAL_PG_USER=etl
LOCAL_PG_PASSWORD=etl
LOCAL_PG_DB=etl_dev
LOCAL_MINIO_USER=minioadmin
LOCAL_MINIO_PASSWORD=minioadmin

# === Runtime ===
ETLX_ENV=local                # local | dev | stg | prod
LOG_LEVEL=INFO

# =============================================================================
# === services/etlx-server (FastAPI) ===========================================
# Settings class: etlx_server/settings.py (pydantic-settings). All fields are
# read from env vars (case-insensitive); a `.env` file at process CWD is also
# loaded if present.
# =============================================================================

# --- service identity ---
SERVICE_NAME=etlx-server
ENVIRONMENT=development       # development | staging | production
                              # `production` hides /docs and /redoc.

# --- metadata DB ---
# SQLAlchemy async URL. Use the +asyncpg driver. For docker-compose.prod.yml
# the host is `metadata-db` (compose service name); for local-dev via
# `etlx dev up` it's `localhost:55432`.
DATABASE_URL=postgresql+asyncpg://etlx:etlx@metadata-db:5432/etlx
DATABASE_ECHO=false

# --- CORS ---
# Pydantic-settings v2 parses list[str] env vars as JSON. Wrap origins in
# JSON brackets — a bare comma-separated list raises SettingsError.
CORS_ORIGINS=["http://localhost:3000"]

# --- JWT (ADR-0023) ---
# RS256 keypair. Generate with: `etlx admin gen-jwt-keys --out-dir .run`
# Both PEM bodies (full multi-line) go into the env vars verbatim. In
# Kubernetes, mount as a Secret and project into env; in compose, export
# from `.run/` files.
AUTH_JWT_PRIVATE_KEY_PEM=
AUTH_JWT_PUBLIC_KEY_PEM=
AUTH_JWT_ISSUER=etlx-server
AUTH_JWT_AUDIENCE=etlx
AUTH_JWT_ACCESS_TTL_SECONDS=900       # 15 min
AUTH_JWT_REFRESH_TTL_SECONDS=604800   # 7 days

# --- auth flow toggles ---
AUTH_LOCAL_ENABLED=true               # email + bcrypt fallback
AUTH_OIDC_ENABLED=false               # set true + populate providers below
AUTH_OIDC_STATE_TTL_SECONDS=300

# OIDC providers: JSON array of objects. Example for Google:
#   [{"name":"google","display_name":"Google","client_id":"...",
#     "client_secret":"...","discovery_url":"https://accounts.google.com/.well-known/openid-configuration"}]
AUTH_OIDC_PROVIDERS=[]

# --- secret backend ---
# Which backend resolves ${SECRET:<path>} placeholders in connection configs.
# env: read from process env (read-only, default)
# file: JSON file at FILE_SECRET_PATH (dev only)
# vault | aws_sm | gcp_sm: real backends — see ADR-0017 §6.
SECRET_BACKEND=env
FILE_SECRET_PATH=                     # required when SECRET_BACKEND=file

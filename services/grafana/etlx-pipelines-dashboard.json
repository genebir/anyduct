{
  "uid": "anyduct-pipelines",
  "title": "anyduct — pipeline operations",
  "tags": [
    "anyduct",
    "etl-plugins"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "label": "Data source",
        "current": {}
      },
      {
        "name": "pipeline",
        "type": "query",
        "label": "Pipeline",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "query": "label_values(etl_plugins_records_read_total, pipeline)",
        "includeAll": true,
        "multi": true,
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Records throughput (rows/s)",
      "description": "Read vs written per pipeline. A persistent gap = filtering/dedupe/DLQ routing.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (pipeline) (rate(etl_plugins_records_read_total{pipeline=~\"$pipeline\"}[$__rate_interval]))",
          "legendFormat": "{{pipeline}} read",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        },
        {
          "refId": "B",
          "expr": "sum by (pipeline) (rate(etl_plugins_records_written_total{pipeline=~\"$pipeline\"}[$__rate_interval]))",
          "legendFormat": "{{pipeline}} written",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Run duration p95 (s)",
      "description": "Pipeline run duration percentiles from the core histogram.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, pipeline) (rate(etl_plugins_duration_seconds_bucket{pipeline=~\"$pipeline\"}[$__rate_interval])))",
          "legendFormat": "{{pipeline}} p95",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.50, sum by (le, pipeline) (rate(etl_plugins_duration_seconds_bucket{pipeline=~\"$pipeline\"}[$__rate_interval])))",
          "legendFormat": "{{pipeline}} p50",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Runs completed / min",
      "description": "Each run records one duration sample — count increase = completed runs.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (pipeline) (increase(etl_plugins_duration_seconds_count{pipeline=~\"$pipeline\"}[5m]))",
          "legendFormat": "{{pipeline}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Errors & DLQ-routed records /s",
      "description": "routed=\"dlq\" series = bad records captured by the dead-letter queue (partial success), other series = hard errors.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (pipeline, routed) (rate(etl_plugins_errors_total{pipeline=~\"$pipeline\"}[$__rate_interval]))",
          "legendFormat": "{{pipeline}} {{routed}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Stream lag (s)",
      "description": "Streaming pipelines only — records' event-time lag.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max by (pipeline) (etl_plugins_lag_seconds{pipeline=~\"$pipeline\"})",
          "legendFormat": "{{pipeline}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ]
    }
  ],
  "annotations": {
    "list": []
  },
  "editable": true
}
